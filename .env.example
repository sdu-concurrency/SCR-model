# Application title baked into the frontend HTML <title> at build time.
# Defaults to "Process model - Supply Chain Resilience" if not set.
VITE_APP_TITLE=

# Base URL of the PocketBase API, used by the Vue frontend to reach the backend.
# Defaults to the browser's current origin (window.location.origin) if not set,
# which is correct when the frontend and backend are served from the same host.
# Override for local development when the dev server runs on a different port:
#   VITE_API_URL=http://127.0.0.1:8090
VITE_API_URL=
